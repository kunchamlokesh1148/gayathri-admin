rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to fetch the user's admin profile
    function getAdminData() {
      return get(/databases/$(database)/documents/adminCredentials/$(request.auth.uid)).data;
    }
    
    // Helper function to check if the user is an active admin
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/adminCredentials/$(request.auth.uid));
    }
    
    // Helper function to check specific admin roles
    function isSuperAdmin() {
      return isAdmin() && getAdminData().role == 'Super Admin';
    }
    
    function isManager() {
      return isAdmin() && (getAdminData().role == 'Super Admin' || getAdminData().role == 'Manager');
    }
    
    // 1. adminCredentials rules
    match /adminCredentials/{uid} {
      allow read: if isAdmin();
      allow write: if isAuthenticated() && isSuperAdmin();
    }
    
    // 2. products rules
    match /products/{productId} {
      allow read: if true; // Public read for customer portal catalog
      allow write: if isAdmin() && isManager();
    }
    
    // 3. categories and brands rules
    match /categories/{categoryId} {
      allow read: if true; // Public read for customer portal selectors
      allow write: if isAdmin() && isManager();
    }
    
    match /brands/{brandId} {
      allow read: if true; // Public read for customer portal selectors
      allow write: if isAdmin() && isManager();
    }
    
    // 4. orders rules
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow create: if true; // Anyone can place an order (or check authentication if customer portal requires login)
      allow update, delete: if isAdmin() && getAdminData().role != 'Staff'; // Staff is read-only
    }
    
    // 5. customers rules
    match /customers/{customerId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == customerId);
      allow create: if true; // Public registration
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == customerId);
    }
    
    // 6. deliveryStaff rules
    match /deliveryStaff/{staffId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == staffId);
      allow write: if isAdmin() && isSuperAdmin();
    }
    
    // 7. settings rules
    match /settings/{settingId} {
      allow read: if true; // Public read for store info and business hours
      allow write: if isAdmin() && isManager();
    }
    
    // 8. homepageCarousel rules
    match /homepageCarousel/{bannerId} {
      allow read: if true; // Public read for banners on homepage
      allow write: if isAdmin() && isManager();
    }
  }
}
